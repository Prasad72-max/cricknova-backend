rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /subscriptions/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      match /bowling_sessions/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      match /certificates/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      match /summary/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      match /{subCollection}/{docId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // Premium device bindings (per-user)
    match /premium_device_bindings/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // Security logs (write-only for authed users)
    match /security_logs/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // Bat orders (allow any authenticated user)
    match /bat_orders/{docId} {
      allow read, write: if request.auth != null;
    }

    // MONTHLY USAGE (TEMPORARY DEBUG: allow any authed user)
    match /usage_table/{docId} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
